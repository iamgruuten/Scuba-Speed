VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_web_app_id
VITE_FIREBASE_REGION=asia-southeast1
VITE_RECAPTCHA_SITE_KEY=your_recaptcha_v3_or_enterprise_site_key

# Local only. Register the debug token printed in the console in Firebase App Check.
# VITE_APPCHECK_DEBUG_TOKEN=true
# VITE_USE_FIREBASE_EMULATORS=true
